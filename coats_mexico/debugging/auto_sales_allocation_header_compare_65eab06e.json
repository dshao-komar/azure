            "text": "USE P21;\nSET NOCOUNT ON;\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\nDECLARE @Target int=682, @Good int=681;\nSELECT result_set='header_compare', sample_name=CASE WHEN container_receipts_hdr_uid=@Target THEN 'TARGET' ELSE 'KNOWN_GOOD' END, container_receipts_hdr_uid=CONVERT(varchar(50),container_receipts_hdr_uid), vessel_receipts_container_uid=CONVERT(varchar(50),vessel_receipts_container_uid), date_received=CONVERT(varchar(30),date_received,121), period=CONVERT(varchar(50),period), year_for_period=CONVERT(varchar(50),year_for_period), row_status_flag=CONVERT(varchar(50),row_status_flag), date_created=CONVERT(varchar(30),date_created,121), created_by, date_last_modified=CONVERT(varchar(30),date_last_modified,121), last_maintained_by, receiving_location_id=CONVERT(varchar(50),receiving_location_id), currency_line_uid=CONVERT(varchar(50),currency_line_uid), exchange_date=CONVERT(varchar(30),exchange_date,121), rfnav_trans_no=CONVERT(varchar(50),rfnav_trans_no), processing, processing_by\nFROM dbo.container_receipts_hdr WHERE container_receipts_hdr_uid IN (@Target,@Good)\nORDER BY sample_name DESC;\nSELECT result_set='vessel_container_compare', sample_name=CASE WHEN crh.container_receipts_hdr_uid=@Target THEN 'TARGET' ELSE 'KNOWN_GOOD' END, crh_uid=CONVERT(varchar(50),crh.container_receipts_hdr_uid), vc.*\nFROM dbo.container_receipts_hdr crh JOIN dbo.vessel_receipts_container vc ON vc.vessel_receipts_container_uid=crh.vessel_receipts_container_uid WHERE crh.container_receipts_hdr_uid IN (@Target,@Good);",
            "type": "Query"
          }
