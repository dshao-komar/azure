            "text": "USE P21;\nSET NOCOUNT ON;\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\nSELECT result_set='container_receipts_hdr_columns', column_id=CONVERT(varchar(20), c.column_id), column_name=c.name, type_name=ty.name, max_length=CONVERT(varchar(20), c.max_length), is_nullable=CONVERT(varchar(5), c.is_nullable)\nFROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.container_receipts_hdr') ORDER BY c.column_id;\nSELECT result_set='container_receipts_line_columns', column_id=CONVERT(varchar(20), c.column_id), column_name=c.name, type_name=ty.name, max_length=CONVERT(varchar(20), c.max_length), is_nullable=CONVERT(varchar(5), c.is_nullable)\nFROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.container_receipts_line') ORDER BY c.column_id;\nSELECT result_set='transfer_hdr_columns', column_id=CONVERT(varchar(20), c.column_id), column_name=c.name, type_name=ty.name, max_length=CONVERT(varchar(20), c.max_length), is_nullable=CONVERT(varchar(5), c.is_nullable)\nFROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.transfer_hdr') ORDER BY c.column_id;\nSELECT result_set='transfer_line_columns', column_id=CONVERT(varchar(20), c.column_id), column_name=c.name, type_name=ty.name, max_length=CONVERT(varchar(20), c.max_length), is_nullable=CONVERT(varchar(5), c.is_nullable)\nFROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.transfer_line') ORDER BY c.column_id;\nSELECT result_set='module_hits', object_name=OBJECT_SCHEMA_NAME(m.object_id)+'.'+OBJECT_NAME(m.object_id), type_desc=o.type_desc\nFROM sys.sql_modules m JOIN sys.objects o ON o.object_id=m.object_id\nWHERE m.definition LIKE '%container_receipts%' AND (m.definition LIKE '%alloc%' OR m.definition LIKE '%Allocate%' OR m.definition LIKE '%transfer%')\nORDER BY object_name;",
            "type": "Query"
          }
