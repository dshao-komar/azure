        "scriptBlockExecutionTimeout": "00:10:00",
        "scripts": [
          {
            "text": "USE P21;\nSET NOCOUNT ON;\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\nDECLARE @TargetContainerReceiptsHdrUid int=682, @KnownGoodContainerReceiptsHdrUid int=681, @TargetLocationId decimal(19,0)=210;\nDROP TABLE IF EXISTS #scope; DROP TABLE IF EXISTS #receipt_item;\nCREATE TABLE #scope(sample_name varchar(20), container_receipts_hdr_uid int, receipt_modified datetime);\nINSERT #scope\nSELECT 'TARGET', container_receipts_hdr_uid, date_last_modified FROM dbo.container_receipts_hdr WHERE container_receipts_hdr_uid=@TargetContainerReceiptsHdrUid\nUNION ALL SELECT 'KNOWN_GOOD', container_receipts_hdr_uid, date_last_modified FROM dbo.container_receipts_hdr WHERE container_receipts_hdr_uid=@KnownGoodContainerReceiptsHdrUid;\nCREATE TABLE #receipt_item(sample_name varchar(20), inv_mast_uid int, item_id varchar(40), receipt_qty decimal(19,9));\nINSERT #receipt_item\nSELECT s.sample_name, pol.inv_mast_uid, MIN(im.item_id), SUM(crl.qty_received)\nFROM #scope s JOIN dbo.container_receipts_line crl ON crl.container_receipts_hdr_uid=s.container_receipts_hdr_uid\nJOIN dbo.vessel_receipts_line vl ON vl.vessel_receipts_line_uid=crl.vessel_receipts_line_uid\nJOIN dbo.po_line pol ON pol.po_line_uid=vl.po_line_uid\nJOIN dbo.inv_mast im ON im.inv_mast_uid=pol.inv_mast_uid\nGROUP BY s.sample_name, pol.inv_mast_uid;\n\nSELECT result_set='receipt_dates', sample_name, container_receipts_hdr_uid=CONVERT(varchar(50),container_receipts_hdr_uid), receipt_modified=CONVERT(varchar(30),receipt_modified,121) FROM #scope;\n\nSELECT result_set='transfer_hdr_near_receipt', s.sample_name, transfer_no=CONVERT(varchar(50),th.transfer_no), from_location_id=CONVERT(varchar(50),th.from_location_id), to_location_id=CONVERT(varchar(50),th.to_location_id), transfer_date=CONVERT(varchar(30),th.transfer_date,121), planned_recpt_date=CONVERT(varchar(30),th.planned_recpt_date,121), shipping_date=CONVERT(varchar(30),th.shipping_date,121), received_date=CONVERT(varchar(30),th.received_date,121), date_created=CONVERT(varchar(30),th.date_created,121), date_last_modified=CONVERT(varchar(30),th.date_last_modified,121), created_by=th.created_by, last_maintained_by=th.last_maintained_by, approved=th.approved, shipped_flag=th.shipped_flag, complete_flag=th.complete_flag, oe_transfer_reserve_flag=th.oe_transfer_reserve_flag, source_type_cd=CONVERT(varchar(50),th.source_type_cd), line_count=CONVERT(varchar(50),COUNT(tl.line_no)), matching_receipt_item_count=CONVERT(varchar(50),COUNT(DISTINCT ri.inv_mast_uid)), qty_to_transfer=CONVERT(varchar(50),SUM(COALESCE(tl.qty_to_transfer,0))), qty_transferred=CONVERT(varchar(50),SUM(COALESCE(tl.qty_transferred,0))), qty_received=CONVERT(varchar(50),SUM(COALESCE(tl.qty_received,0))), qty_reserved=CONVERT(varchar(50),SUM(COALESCE(tl.qty_reserved,0)))\nFROM #scope s\nJOIN dbo.transfer_hdr th ON th.date_created BETWEEN DATEADD(day,-1,s.receipt_modified) AND DATEADD(day,1,s.receipt_modified)\nJOIN dbo.transfer_line tl ON tl.transfer_no=th.transfer_no\nLEFT JOIN #receipt_item ri ON ri.sample_name=s.sample_name AND ri.inv_mast_uid=tl.inv_mast_uid\nWHERE (th.from_location_id=@TargetLocationId OR th.to_location_id=@TargetLocationId)\nGROUP BY s.sample_name, th.transfer_no, th.from_location_id, th.to_location_id, th.transfer_date, th.planned_recpt_date, th.shipping_date, th.received_date, th.date_created, th.date_last_modified, th.created_by, th.last_maintained_by, th.approved, th.shipped_flag, th.complete_flag, th.oe_transfer_reserve_flag, th.source_type_cd\nHAVING COUNT(DISTINCT ri.inv_mast_uid) > 0\nORDER BY s.sample_name, matching_receipt_item_count DESC, th.date_created DESC;\n\nSELECT result_set='anticipated_allocation_for_receipt_items', ri.sample_name, source='by_inbound_transfer_no', aa.inbound_transaction_no, inbound_transaction_type_cd=CONVERT(varchar(50),aa.inbound_transaction_type_cd), outbound_transaction_type_cd=CONVERT(varchar(50),aa.outbound_transaction_type_cd), allocation_rows=CONVERT(varchar(50),COUNT(*)), sku_qty_to_be_allocated=CONVERT(varchar(50),SUM(aa.sku_qty_to_be_allocated)), hard_linked_count=CONVERT(varchar(50),SUM(CASE WHEN aa.hard_linked_flag='Y' THEN 1 ELSE 0 END))\nFROM #receipt_item ri\nJOIN anticipated_allocation aa ON aa.inv_mast_uid=ri.inv_mast_uid AND aa.location_id=@TargetLocationId\nGROUP BY ri.sample_name, aa.inbound_transaction_no, aa.inbound_transaction_type_cd, aa.outbound_transaction_type_cd\nORDER BY ri.sample_name, allocation_rows DESC;",
            "type": "Query"
          }
        ]
      },
