            "text": "USE P21;\nSET NOCOUNT ON;\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\n\nSELECT result_set='module_definition_hit', object_name=OBJECT_SCHEMA_NAME(m.object_id)+'.'+OBJECT_NAME(m.object_id), line_no=CONVERT(varchar(20), v.line_no), line_text=v.line_text\nFROM sys.sql_modules m\nJOIN sys.objects o ON o.object_id=m.object_id\nCROSS APPLY (\n    SELECT ROW_NUMBER() OVER (ORDER BY (SELECT 1)) AS line_no, value AS line_text\n    FROM STRING_SPLIT(REPLACE(REPLACE(m.definition, CHAR(13), ''), CHAR(10), CHAR(30)), CHAR(30))\n) v\nWHERE OBJECT_SCHEMA_NAME(m.object_id)+'.'+OBJECT_NAME(m.object_id) IN ('dbo.p21_create_container_receipt_records','dbo.p21_move_hard_allocations')\n  AND (v.line_text LIKE '%alloc%' OR v.line_text LIKE '%container_receipts%' OR v.line_text LIKE '%transfer%' OR v.line_text LIKE '%reserve%' OR v.line_text LIKE '%hard%')\nORDER BY object_name, TRY_CONVERT(int,line_no);\n\nSELECT result_set='proc_parameters', object_name=OBJECT_SCHEMA_NAME(p.object_id)+'.'+OBJECT_NAME(p.object_id), parameter_id=CONVERT(varchar(20), p.parameter_id), parameter_name=p.name, type_name=TYPE_NAME(p.user_type_id), max_length=CONVERT(varchar(20), p.max_length), is_output=CONVERT(varchar(5), p.is_output)\nFROM sys.parameters p\nWHERE OBJECT_SCHEMA_NAME(p.object_id)+'.'+OBJECT_NAME(p.object_id) IN ('dbo.p21_create_container_receipt_records','dbo.p21_move_hard_allocations')\nORDER BY object_name, p.parameter_id;",
            "type": "Query"
          }
        ]
