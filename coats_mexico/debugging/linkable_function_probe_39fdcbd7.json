                                    "scriptBlockExecutionTimeout":  "00:10:00",
                                    "scripts":  [
                                                    {
                                                        "text":  "USE P21Play;\nSET NOCOUNT ON;\n\nDECLARE @PoNo decimal(19,0)=6070127;\nDECLARE @ItemId nvarchar(40)=N\u002711880 528SY\u0027;\nDECLARE @LocationId decimal(19,0)=210;\nDECLARE @CompanyId varchar(8)=\u0027KA\u0027;\nDECLARE @InvMastUid int;\nDECLARE @PoLineUid int;\nDECLARE @PoLineNo int;\n\nSELECT TOP (1)\n      @InvMastUid = im.inv_mast_uid\nFROM dbo.inv_mast AS im\nWHERE im.item_id = @ItemId;\n\nSELECT TOP (1)\n      @PoLineUid = pol.po_line_uid\n    , @PoLineNo = pol.line_no\nFROM dbo.po_line AS pol\nWHERE pol.po_no = @PoNo\n  AND pol.inv_mast_uid = @InvMastUid\nORDER BY pol.po_line_uid;\n\nSELECT\n      section=\u0027inputs\u0027\n    , po_no=CONVERT(nvarchar(40), @PoNo)\n    , item_id=@ItemId\n    , inv_mast_uid=CONVERT(nvarchar(40), @InvMastUid)\n    , po_line_uid=CONVERT(nvarchar(40), @PoLineUid)\n    , po_line_no=CONVERT(nvarchar(40), @PoLineNo);\n\nSELECT TOP (1)\n      section=\u0027function_object\u0027\n    , object_id=CONVERT(nvarchar(40), OBJECT_ID(\u0027dbo.p21_fnt_get_linkable_transactions\u0027))\n    , object_type=o.type_desc\n    , create_date=CONVERT(nvarchar(30), o.create_date, 126)\n    , modify_date=CONVERT(nvarchar(30), o.modify_date, 126)\nFROM sys.objects AS o\nWHERE o.object_id = OBJECT_ID(\u0027dbo.p21_fnt_get_linkable_transactions\u0027);\n\nSELECT TOP (20)\n      section=\u0027definition_line\u0027\n    , line_no=CONVERT(nvarchar(20), ROW_NUMBER() OVER (ORDER BY (SELECT 1)))\n    , definition_line=value\nFROM STRING_SPLIT(CONVERT(nvarchar(max), OBJECT_DEFINITION(OBJECT_ID(\u0027dbo.p21_fnt_get_linkable_transactions\u0027))), CHAR(10))\nWHERE value LIKE \u0027%linked%\u0027\n   OR value LIKE \u0027%oe_line%\u0027\n   OR value LIKE \u0027%po_line%\u0027\n   OR value LIKE \u0027%backorder%\u0027\n   OR value LIKE \u0027%qty_allocated%\u0027;\n\nSELECT\n      section=\u0027po_line\u0027\n    , po_no=CONVERT(nvarchar(40), pol.po_no)\n    , po_line_uid=CONVERT(nvarchar(40), pol.po_line_uid)\n    , line_no=CONVERT(nvarchar(20), pol.line_no)\n    , complete=pol.complete\n    , cancel_flag=pol.cancel_flag\n    , qty_ordered=CONVERT(nvarchar(60), pol.qty_ordered)\n    , qty_received=CONVERT(nvarchar(60), pol.qty_received)\n    , unit_of_measure=pol.unit_of_measure\n    , inv_mast_uid=CONVERT(nvarchar(40), pol.inv_mast_uid)\n    , item_id=im.item_id\nFROM dbo.po_line AS pol\nJOIN dbo.inv_mast AS im ON im.inv_mast_uid=pol.inv_mast_uid\nWHERE pol.po_no=@PoNo AND pol.inv_mast_uid=@InvMastUid;\n\nSELECT\n      section=\u0027inv_loc\u0027\n    , location_id=CONVERT(nvarchar(40), il.location_id)\n    , qty_on_hand=CONVERT(nvarchar(60), il.qty_on_hand)\n    , qty_allocated=CONVERT(nvarchar(60), il.qty_allocated)\n    , qty_backordered=CONVERT(nvarchar(60), il.qty_backordered)\n    , order_quantity=CONVERT(nvarchar(60), il.order_quantity)\n    , qty_in_transit=CONVERT(nvarchar(60), il.qty_in_transit)\n    , date_last_modified=CONVERT(nvarchar(30), il.date_last_modified, 126)\nFROM dbo.inv_loc AS il\nWHERE il.company_id=@CompanyId\n  AND il.location_id=@LocationId\n  AND il.inv_mast_uid=@InvMastUid;\n\nSELECT TOP (50)\n      section=\u0027oe_line_po\u0027\n    , table_name=\u0027oe_line_po\u0027\n    , order_number=CONVERT(nvarchar(40), olp.order_number)\n    , line_number=CONVERT(nvarchar(40), olp.line_number)\n    , po_no=CONVERT(nvarchar(40), olp.po_no)\n    , po_line_number=CONVERT(nvarchar(40), olp.po_line_number)\n    , connection_type=CONVERT(nvarchar(40), olp.connection_type)\nFROM dbo.oe_line_po AS olp\nWHERE olp.po_no=@PoNo\n  AND (olp.po_line_number=@PoLineNo OR @PoLineNo IS NULL)\nORDER BY olp.order_number, olp.line_number;\n\nSELECT TOP (50)\n      section=\u0027linked_oe_lines\u0027\n    , oh.order_no\n    , ol.line_no\n    , oe_line_uid=CONVERT(nvarchar(40), ol.oe_line_uid)\n    , ol.complete\n    , oh.rma_flag\n    , ship_loc_id=CONVERT(nvarchar(40), ol.ship_loc_id)\n    , qty_ordered=CONVERT(nvarchar(60), ol.qty_ordered)\n    , qty_allocated=CONVERT(nvarchar(60), ol.qty_allocated)\n    , qty_on_pick_tickets=CONVERT(nvarchar(60), ol.qty_on_pick_tickets)\n    , qty_invoiced=CONVERT(nvarchar(60), ol.qty_invoiced)\n    , qty_canceled=CONVERT(nvarchar(60), ol.qty_canceled)\nFROM dbo.oe_line_po AS olp\nJOIN dbo.oe_hdr AS oh ON oh.order_no=olp.order_number\nJOIN dbo.oe_line AS ol ON ol.order_no=olp.order_number AND ol.line_no=olp.line_number\nWHERE olp.po_no=@PoNo\n  AND (olp.po_line_number=@PoLineNo OR @PoLineNo IS NULL)\nORDER BY oh.order_no, ol.line_no;\n\nSELECT TOP (50)\n      section=\u0027receipt_lines\u0027\n    , crh.container_receipts_hdr_uid\n    , crh.row_status_flag AS crh_status\n    , vrl.po_line_uid\n    , crl.container_receipts_line_uid\n    , qty_received=CONVERT(nvarchar(60), crl.qty_received)\n    , crl.transfer_flag\n    , crl.complete_po_line_flag\n    , vrc.container_name\n    , vrh.vessel_name\nFROM dbo.container_receipts_line AS crl\nJOIN dbo.container_receipts_hdr AS crh ON crh.container_receipts_hdr_uid=crl.container_receipts_hdr_uid\nJOIN dbo.vessel_receipts_line AS vrl ON vrl.vessel_receipts_line_uid=crl.vessel_receipts_line_uid\nJOIN dbo.vessel_receipts_container AS vrc ON vrc.vessel_receipts_container_uid=crh.vessel_receipts_container_uid\nJOIN dbo.vessel_receipts_hdr AS vrh ON vrh.vessel_receipts_hdr_uid=vrc.vessel_receipts_hdr_uid\nWHERE vrl.po_line_uid=@PoLineUid\nORDER BY crh.container_receipts_hdr_uid DESC;",
                                                        "type":  "Query"
                                                    }
                                                ]
