        "scripts": [
          {
            "text": "USE P21Play;\nSET NOCOUNT ON;\nDECLARE @ShipmentFileId uniqueidentifier = 'f5c975af-1d81-5d36-9ff8-244fd38c9fc5';\nDECLARE @ContainerReceiptsHdrUid int = 682;\nDECLARE @VesselReceiptsHdrUid int = 762;\nDECLARE @ContainerBuildingUid int = 900;\n\n;WITH s AS (\n    SELECT po_line_uid, qty = SUM(CONVERT(decimal(19,9), Invoiced_Qty))\n    FROM P21Import.dbo.coats_mexico_shipment_pallet_line\n    WHERE shipment_file_id = @ShipmentFileId\n      AND po_line_uid IS NOT NULL\n      AND Invoiced_Qty IS NOT NULL\n    GROUP BY po_line_uid\n), expected AS (\n    SELECT line_count = COUNT(*), total_qty = SUM(qty)\n    FROM s\n), vlinks AS (\n    SELECT link_rows = COUNT(*), link_qty = COALESCE(SUM(CONVERT(decimal(19,9), quantity_on_po)),0)\n    FROM dbo.oe_line_po\n    WHERE po_no = @VesselReceiptsHdrUid\n      AND connection_type = 'V'\n      AND ISNULL(delete_flag,'N') = 'N'\n      AND ISNULL(cancel_flag,'N') = 'N'\n), open_vlinks AS (\n    SELECT open_link_rows = COUNT(*), open_link_qty = COALESCE(SUM(CONVERT(decimal(19,9), quantity_on_po)),0)\n    FROM dbo.oe_line_po\n    WHERE po_no = @VesselReceiptsHdrUid\n      AND connection_type = 'V'\n      AND ISNULL(delete_flag,'N') = 'N'\n      AND ISNULL(cancel_flag,'N') = 'N'\n      AND ISNULL(completed,'N') = 'N'\n), old_plinks AS (\n    SELECT open_original_po_link_rows = COUNT(*), open_original_po_link_qty = COALESCE(SUM(CONVERT(decimal(19,9), quantity_on_po)),0)\n    FROM dbo.oe_line_po AS olp\n    INNER JOIN dbo.po_line AS pol\n      ON pol.po_no = olp.po_no\n     AND pol.line_no = olp.po_line_number\n    INNER JOIN s\n      ON s.po_line_uid = pol.po_line_uid\n    WHERE olp.connection_type = 'P'\n      AND ISNULL(olp.delete_flag,'N') = 'N'\n      AND ISNULL(olp.cancel_flag,'N') = 'N'\n      AND ISNULL(olp.completed,'N') = 'N'\n)\nSELECT result_set='summary',\n       expected_lines = CONVERT(varchar(30), e.line_count),\n       expected_qty = CONVERT(varchar(40), e.total_qty),\n       cbp_rows = CONVERT(varchar(30), (SELECT COUNT(*) FROM dbo.container_building_po WHERE container_building_uid=@ContainerBuildingUid)),\n       vrl_rows = CONVERT(varchar(30), (SELECT COUNT(*) FROM dbo.vessel_receipts_line WHERE vessel_receipts_hdr_uid=@VesselReceiptsHdrUid)),\n       vrl_qty = CONVERT(varchar(40), (SELECT SUM(CONVERT(decimal(19,9), container_qty_received)) FROM dbo.vessel_receipts_line WHERE vessel_receipts_hdr_uid=@VesselReceiptsHdrUid)),\n       crl_rows = CONVERT(varchar(30), (SELECT COUNT(*) FROM dbo.container_receipts_line WHERE container_receipts_hdr_uid=@ContainerReceiptsHdrUid)),\n       crl_qty = CONVERT(varchar(40), (SELECT SUM(CONVERT(decimal(19,9), qty_received)) FROM dbo.container_receipts_line WHERE container_receipts_hdr_uid=@ContainerReceiptsHdrUid)),\n       vlink_rows = CONVERT(varchar(30), v.link_rows),\n       vlink_qty = CONVERT(varchar(40), v.link_qty),\n       open_vlink_rows = CONVERT(varchar(30), ov.open_link_rows),\n       open_vlink_qty = CONVERT(varchar(40), ov.open_link_qty),\n       open_original_po_link_rows = CONVERT(varchar(30), op.open_original_po_link_rows),\n       open_original_po_link_qty = CONVERT(varchar(40), op.open_original_po_link_qty)\nFROM expected e CROSS JOIN vlinks v CROSS JOIN open_vlinks ov CROSS JOIN old_plinks op;\n\nSELECT TOP (20) result_set='vessel_link_sample', order_number=CONVERT(varchar(30), order_number), line_number=CONVERT(varchar(30), line_number), po_no=CONVERT(varchar(30), po_no), po_line_number=CONVERT(varchar(30), po_line_number), quantity_on_po=CONVERT(varchar(40), quantity_on_po), completed, connection_type\nFROM dbo.oe_line_po\nWHERE po_no = @VesselReceiptsHdrUid\n  AND connection_type = 'V'\nORDER BY po_line_number, order_number, line_number;",
            "type": "Query"
          }
        ]
      },
