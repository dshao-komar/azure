        "scripts": [
          {
            "text": "USE P21;\nSET NOCOUNT ON;\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\nDECLARE @TargetStart decimal(19,0)=9010472, @TargetEnd decimal(19,0)=9010490, @GoodStart decimal(19,0)=9010440, @GoodEnd decimal(19,0)=9010450;\nSELECT result_set='transfer_backorders_columns', column_id=CONVERT(varchar(20),c.column_id), column_name=c.name, type_name=ty.name FROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.transfer_backorders') ORDER BY c.column_id;\nSELECT result_set='transfer_backorders_detail_columns', column_id=CONVERT(varchar(20),c.column_id), column_name=c.name, type_name=ty.name FROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.transfer_backorders_detail') ORDER BY c.column_id;\nSELECT result_set='transfer_backorders_rows', sample_name=CASE WHEN tb.transfer_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END, transfer_no=CONVERT(varchar(50),tb.transfer_no), rows_count=CONVERT(varchar(50),COUNT(*))\nFROM transfer_backorders tb WHERE tb.transfer_no BETWEEN @TargetStart AND @TargetEnd OR tb.transfer_no BETWEEN @GoodStart AND @GoodEnd GROUP BY CASE WHEN tb.transfer_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END,tb.transfer_no ORDER BY sample_name, transfer_no;\nSELECT result_set='transfer_backorders_detail_rows', sample_name=CASE WHEN tbd.transfer_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END, transfer_no=CONVERT(varchar(50),tbd.transfer_no), rows_count=CONVERT(varchar(50),COUNT(*))\nFROM transfer_backorders_detail tbd WHERE tbd.transfer_no BETWEEN @TargetStart AND @TargetEnd OR tbd.transfer_no BETWEEN @GoodStart AND @GoodEnd GROUP BY CASE WHEN tbd.transfer_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END,tbd.transfer_no ORDER BY sample_name, transfer_no;",
            "type": "Query"
          }
        ]
