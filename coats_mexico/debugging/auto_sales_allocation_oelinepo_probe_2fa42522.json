        "scripts": [
          {
            "text": "USE P21;\nSET NOCOUNT ON; SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\nDECLARE @TargetStart decimal(19,0)=9010472, @TargetEnd decimal(19,0)=9010490, @GoodStart decimal(19,0)=9010440, @GoodEnd decimal(19,0)=9010450;\nSELECT result_set='oe_line_po_columns', column_id=CONVERT(varchar(20),c.column_id), column_name=c.name, type_name=ty.name FROM sys.columns c JOIN sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID('dbo.oe_line_po') ORDER BY c.column_id;\nSELECT result_set='oe_line_po_transfer_links', sample_name=CASE WHEN po_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END, po_no=CONVERT(varchar(50),po_no), connection_type, rows_count=CONVERT(varchar(50),COUNT(*)), quantity_on_po=CONVERT(varchar(50),SUM(quantity_on_po)), completed_y=CONVERT(varchar(50),SUM(CASE WHEN completed='Y' THEN 1 ELSE 0 END)), cancel_y=CONVERT(varchar(50),SUM(CASE WHEN cancel_flag='Y' THEN 1 ELSE 0 END))\nFROM dbo.oe_line_po\nWHERE (po_no BETWEEN @TargetStart AND @TargetEnd OR po_no BETWEEN @GoodStart AND @GoodEnd)\nGROUP BY CASE WHEN po_no BETWEEN @TargetStart AND @TargetEnd THEN 'TARGET' ELSE 'KNOWN_GOOD' END, po_no, connection_type\nORDER BY sample_name, po_no;",
            "type": "Query"
          }
        ]
