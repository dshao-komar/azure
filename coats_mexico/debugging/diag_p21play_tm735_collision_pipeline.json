                                                                     "scripts":  [
                                                                                     {
                                                                                         "text":  "USE P21Play;\nSET NOCOUNT ON;\nDECLARE @TrailerName nvarchar(255)=N\u0027TM735\u0027;\nDECLARE @ShipmentDate date=\u00272026-05-11\u0027;\nSELECT result_name=\u0027container_building\u0027, row_count=CONVERT(nvarchar(20), COUNT(*)) FROM dbo.container_building WHERE location_id=210 AND container_name=@TrailerName;\nSELECT result_name=\u0027vessel_receipts_hdr\u0027, row_count=CONVERT(nvarchar(20), COUNT(*)) FROM dbo.vessel_receipts_hdr WHERE location_id=210 AND vessel_name=@TrailerName AND departure_date=@ShipmentDate;\nSELECT result_name=\u0027receipt_build_for_tm735\u0027, row_count=CONVERT(nvarchar(20), COUNT(*)) FROM P21Import.dbo.coats_mexico_shipment_receipt_build AS rb JOIN P21Import.dbo.coats_mexico_shipment_file AS f ON f.shipment_file_id=rb.shipment_file_id WHERE f.shipment_date=@ShipmentDate AND f.trailer_name=@TrailerName;",
                                                                                         "type":  "Query"
                                                                                     }
